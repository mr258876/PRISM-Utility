<Page
    x:Class="PRISM_Utility.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:PRISM_Utility.Helpers"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled">
        <Grid>
            <StackPanel
                x:Name="ContentArea">
            <TextBlock x:Uid="Settings_Personalization" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                <TextBlock x:Uid="Settings_Theme" />

                <StackPanel Margin="{StaticResource XSmallTopMargin}">
                    <RadioButton
                        x:Uid="Settings_Theme_Light"
                        Command="{x:Bind ViewModel.SwitchThemeCommand}"
                        IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}"
                        FontSize="15"
                        GroupName="AppTheme">
                        <RadioButton.CommandParameter>
                            <xaml:ElementTheme>Light</xaml:ElementTheme>
                        </RadioButton.CommandParameter>
                    </RadioButton>
                    <RadioButton
                        x:Uid="Settings_Theme_Dark"
                        Command="{x:Bind ViewModel.SwitchThemeCommand}"
                        IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}"
                        FontSize="15"
                        GroupName="AppTheme">
                        <RadioButton.CommandParameter>
                            <xaml:ElementTheme>Dark</xaml:ElementTheme>
                        </RadioButton.CommandParameter>
                    </RadioButton>
                    <RadioButton
                        x:Uid="Settings_Theme_Default"
                        Command="{x:Bind ViewModel.SwitchThemeCommand}"
                        IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default, Mode=OneWay}"
                        FontSize="15"
                        GroupName="AppTheme">
                        <RadioButton.CommandParameter>
                            <xaml:ElementTheme>Default</xaml:ElementTheme>
                        </RadioButton.CommandParameter>
                    </RadioButton>
                </StackPanel>
            </StackPanel>

            <TextBlock x:Uid="Settings_Scanner" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                <ToggleSwitch
                    Header="Mirror program output to Debug console"
                    IsOn="{x:Bind ViewModel.IsDebugConsoleMirrorEnabled, Mode=TwoWay}" />
                <ToggleSwitch
                    Header="Mirror program output to local log file"
                    Margin="0,8,0,0"
                    IsOn="{x:Bind ViewModel.IsDebugFileLogEnabled, Mode=TwoWay}" />
                <ToggleSwitch
                    x:Uid="Settings_MultiBufferedBulkInToggleSwitch"
                    Margin="0,8,0,0"
                    IsOn="{x:Bind ViewModel.IsMultiBufferedBulkInEnabled, Mode=TwoWay}" />
                <ToggleSwitch
                    x:Uid="Settings_RawIoToggleSwitch"
                    Margin="0,8,0,0"
                    IsOn="{x:Bind ViewModel.IsRawIoEnabled, Mode=TwoWay}" />
                <TextBox
                    x:Uid="Settings_RequestBytesTextBox"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.MultiBufferedRequestBytes, Mode=TwoWay}" />
                <TextBox
                    x:Uid="Settings_OutstandingReadsTextBox"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.MultiBufferedOutstandingReads, Mode=TwoWay}" />
                <TextBox
                    x:Uid="Settings_TimeoutMsTextBox"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.MultiBufferedTimeoutMs, Mode=TwoWay}" />
                <Button
                    x:Uid="Settings_RestoreScanTransferDefaultsButton"
                    Margin="0,8,0,0"
                    Command="{x:Bind ViewModel.RestoreScanTransferDefaultsCommand}" />
                <TextBlock
                    x:Uid="Settings_MultiBufferedBulkInDescription"
                    Margin="0,6,0,0"
                    Opacity="0.8"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBlock Text="Color management" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                <ToggleSwitch
                    Header="Use spectral wavelength mapping for RGB preview and PNG output"
                    IsOn="{x:Bind ViewModel.IsColorManagementEnabled, Mode=TwoWay}" />
                <Grid ColumnSpacing="8" RowSpacing="8" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Grid.Column="0" Header="Red wavelength (nm)" Text="{x:Bind ViewModel.RedWavelengthNm, Mode=TwoWay}" />
                    <TextBox Grid.Row="0" Grid.Column="1" Header="Green wavelength (nm)" Text="{x:Bind ViewModel.GreenWavelengthNm, Mode=TwoWay}" />
                    <TextBox Grid.Row="1" Grid.Column="0" Header="Blue wavelength (nm)" Text="{x:Bind ViewModel.BlueWavelengthNm, Mode=TwoWay}" />
                    <TextBox Grid.Row="1" Grid.Column="1" Header="Output gamma" Text="{x:Bind ViewModel.OutputGamma, Mode=TwoWay}" />
                </Grid>
                <Button
                    Margin="0,8,0,0"
                    Content="Restore color defaults"
                    Command="{x:Bind ViewModel.RestoreColorManagementDefaultsCommand}" />
                <TextBlock
                    Margin="0,6,0,0"
                    Opacity="0.8"
                    Text="These settings are shared by RGB Composite preview and saved PNG output. Raw channel export remains unchanged."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBlock x:Uid="Settings_About" Style="{ThemeResource SubtitleTextBlockStyle}" />

            <StackPanel Margin="{StaticResource XSmallTopMargin}">
                <TextBlock Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" />
                <TextBlock
                    Margin="0,4,0,0"
                    Text="{x:Bind ViewModel.BuildDescription, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.BuildVisibility, Mode=OneWay}"
                    Style="{ThemeResource BodyTextBlockStyle}" />

                <TextBlock
                    x:Uid="Settings_AboutDescription"
                    Margin="{StaticResource XSmallTopMargin}"
                    Style="{ThemeResource BodyTextBlockStyle}" />
                <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink" Margin="{StaticResource SettingsPageHyperlinkButtonMargin}" />
            </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
