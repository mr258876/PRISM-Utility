<Page
    x:Class="PRISM_Utility.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:PRISM_Utility.Helpers"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>
    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled">
        <Grid>
            <StackPanel
                x:Name="ContentArea">
            <TextBlock x:Uid="Settings_Personalization" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                <TextBlock x:Uid="Settings_Theme" />

                <StackPanel Margin="{StaticResource XSmallTopMargin}">
                    <RadioButton
                        x:Uid="Settings_Theme_Light"
                        Command="{x:Bind ViewModel.SwitchThemeCommand}"
                        IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}"
                        FontSize="15"
                        GroupName="AppTheme">
                        <RadioButton.CommandParameter>
                            <xaml:ElementTheme>Light</xaml:ElementTheme>
                        </RadioButton.CommandParameter>
                    </RadioButton>
                    <RadioButton
                        x:Uid="Settings_Theme_Dark"
                        Command="{x:Bind ViewModel.SwitchThemeCommand}"
                        IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}"
                        FontSize="15"
                        GroupName="AppTheme">
                        <RadioButton.CommandParameter>
                            <xaml:ElementTheme>Dark</xaml:ElementTheme>
                        </RadioButton.CommandParameter>
                    </RadioButton>
                    <RadioButton
                        x:Uid="Settings_Theme_Default"
                        Command="{x:Bind ViewModel.SwitchThemeCommand}"
                        IsChecked="{x:Bind ViewModel.ElementTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Default, Mode=OneWay}"
                        FontSize="15"
                        GroupName="AppTheme">
                        <RadioButton.CommandParameter>
                            <xaml:ElementTheme>Default</xaml:ElementTheme>
                        </RadioButton.CommandParameter>
                    </RadioButton>
                </StackPanel>

                <TextBlock
                    x:Uid="Settings_Language"
                    Margin="{StaticResource SmallTopMargin}" />

                <ComboBox
                    Margin="{StaticResource XSmallTopMargin}"
                    ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                    DisplayMemberPath="DisplayName"
                    SelectedValuePath="LanguageTag"
                    SelectedValue="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}" />
            </StackPanel>

             <TextBlock x:Uid="Settings_Scanner" Style="{ThemeResource SubtitleTextBlockStyle}" />
             <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                 <ToggleSwitch
                     x:Uid="Settings_DebugConsoleMirrorToggleSwitch"
                    IsOn="{x:Bind ViewModel.IsDebugConsoleMirrorEnabled, Mode=TwoWay}" />
                <ToggleSwitch
                    x:Uid="Settings_DebugFileLogToggleSwitch"
                    Margin="0,8,0,0"
                    IsOn="{x:Bind ViewModel.IsDebugFileLogEnabled, Mode=TwoWay}" />
                <ToggleSwitch
                    x:Uid="Settings_MultiBufferedBulkInToggleSwitch"
                    Margin="0,8,0,0"
                    IsOn="{x:Bind ViewModel.IsMultiBufferedBulkInEnabled, Mode=TwoWay}" />
                <ToggleSwitch
                    x:Uid="Settings_RawIoToggleSwitch"
                    Margin="0,8,0,0"
                    IsOn="{x:Bind ViewModel.IsRawIoEnabled, Mode=TwoWay}" />
                <TextBox
                    x:Uid="Settings_RequestBytesTextBox"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.MultiBufferedRequestBytes, Mode=TwoWay}" />
                <TextBox
                    x:Uid="Settings_OutstandingReadsTextBox"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.MultiBufferedOutstandingReads, Mode=TwoWay}" />
                <TextBox
                    x:Uid="Settings_TimeoutMsTextBox"
                    Margin="0,8,0,0"
                    Text="{x:Bind ViewModel.MultiBufferedTimeoutMs, Mode=TwoWay}" />
                <Button
                    x:Uid="Settings_RestoreScanTransferDefaultsButton"
                    Margin="0,8,0,0"
                    Command="{x:Bind ViewModel.RestoreScanTransferDefaultsCommand}" />
                 <TextBlock
                     x:Uid="Settings_MultiBufferedBulkInDescription"
                     Margin="0,6,0,0"
                     Opacity="0.8"
                     TextWrapping="WrapWholeWords" />
             </StackPanel>

            <TextBlock x:Uid="Settings_DeviceSettings" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                <TextBlock
                    x:Uid="Settings_DeviceSettingsDescription"
                    Opacity="0.8"
                    TextWrapping="WrapWholeWords" />

                <TextBlock
                    x:Uid="Settings_DeviceSettingsMotor1"
                    Margin="{StaticResource SmallTopMargin}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid Margin="{StaticResource XSmallTopMargin}" ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Uid="Settings_Motor1StepsPerRevolutionTextBox" Text="{x:Bind ViewModel.Motor1StepsPerRevolution, Mode=TwoWay}" />
                    <TextBox Grid.Column="1" x:Uid="Settings_Motor1MicrostepsTextBox" Text="{x:Bind ViewModel.Motor1Microsteps, Mode=TwoWay}" />
                    <TextBox Grid.Column="2" x:Uid="Settings_Motor1LeadLengthTextBox" Text="{x:Bind ViewModel.Motor1LeadLengthMm, Mode=TwoWay}" />
                </Grid>

                <TextBlock
                    x:Uid="Settings_DeviceSettingsMotor2"
                    Margin="{StaticResource SmallTopMargin}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid Margin="{StaticResource XSmallTopMargin}" ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Uid="Settings_Motor2StepsPerRevolutionTextBox" Text="{x:Bind ViewModel.Motor2StepsPerRevolution, Mode=TwoWay}" />
                    <TextBox Grid.Column="1" x:Uid="Settings_Motor2MicrostepsTextBox" Text="{x:Bind ViewModel.Motor2Microsteps, Mode=TwoWay}" />
                    <TextBox Grid.Column="2" x:Uid="Settings_Motor2LeadLengthTextBox" Text="{x:Bind ViewModel.Motor2LeadLengthMm, Mode=TwoWay}" />
                </Grid>

                <TextBlock
                    x:Uid="Settings_DeviceSettingsMotor3"
                    Margin="{StaticResource SmallTopMargin}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid Margin="{StaticResource XSmallTopMargin}" ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Uid="Settings_Motor3StepsPerRevolutionTextBox" Text="{x:Bind ViewModel.Motor3StepsPerRevolution, Mode=TwoWay}" />
                    <TextBox Grid.Column="1" x:Uid="Settings_Motor3MicrostepsTextBox" Text="{x:Bind ViewModel.Motor3Microsteps, Mode=TwoWay}" />
                    <TextBox Grid.Column="2" x:Uid="Settings_Motor3LeadLengthTextBox" Text="{x:Bind ViewModel.Motor3LeadLengthMm, Mode=TwoWay}" />
                </Grid>
                <Button
                    x:Uid="Settings_RestoreDeviceSettingsDefaultsButton"
                    Margin="0,8,0,0"
                    Command="{x:Bind ViewModel.RestoreDeviceSettingsDefaultsCommand}" />
            </StackPanel>

             <TextBlock x:Uid="Settings_ColorManagement" Style="{ThemeResource SubtitleTextBlockStyle}" />
             <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                 <ToggleSwitch
                     x:Uid="Settings_ColorManagementToggleSwitch"
                    IsOn="{x:Bind ViewModel.IsColorManagementEnabled, Mode=TwoWay}" />
                <Grid ColumnSpacing="8" RowSpacing="8" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Grid.Column="0" x:Uid="Settings_RedWavelengthTextBox" Text="{x:Bind ViewModel.RedWavelengthNm, Mode=TwoWay}" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Uid="Settings_GreenWavelengthTextBox" Text="{x:Bind ViewModel.GreenWavelengthNm, Mode=TwoWay}" />
                    <TextBox Grid.Row="1" Grid.Column="0" x:Uid="Settings_BlueWavelengthTextBox" Text="{x:Bind ViewModel.BlueWavelengthNm, Mode=TwoWay}" />
                    <TextBox Grid.Row="1" Grid.Column="1" x:Uid="Settings_OutputGammaTextBox" Text="{x:Bind ViewModel.OutputGamma, Mode=TwoWay}" />
                </Grid>
                <Button
                    x:Uid="Settings_RestoreColorManagementDefaultsButton"
                    Margin="0,8,0,0"
                    Command="{x:Bind ViewModel.RestoreColorManagementDefaultsCommand}" />
                <TextBlock
                    x:Uid="Settings_ColorManagementDescription"
                    Margin="0,6,0,0"
                    Opacity="0.8"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBlock x:Uid="Settings_DngGeometry" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Margin="{StaticResource SmallTopBottomMargin}">
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Grid.Column="0" x:Uid="Settings_DngActiveStartTextBox" Text="{x:Bind ViewModel.DngActiveStart, Mode=TwoWay}" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Uid="Settings_DngActiveEndTextBox" Text="{x:Bind ViewModel.DngActiveEndInclusive, Mode=TwoWay}" />
                    <TextBox Grid.Row="1" Grid.ColumnSpan="2" x:Uid="Settings_DngMaskedRangesTextBox" Text="{x:Bind ViewModel.DngMaskedRanges, Mode=TwoWay}" />
                </Grid>
                <Button
                    x:Uid="Settings_RestoreDngGeometryDefaultsButton"
                    Margin="0,8,0,0"
                    Command="{x:Bind ViewModel.RestoreDngGeometryDefaultsCommand}" />
                <TextBlock
                    x:Uid="Settings_DngGeometryDescription"
                    Margin="0,6,0,0"
                    Opacity="0.8"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <TextBlock x:Uid="Settings_About" Style="{ThemeResource SubtitleTextBlockStyle}" />

            <StackPanel Margin="{StaticResource XSmallTopMargin}">
                <TextBlock Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" />
                <TextBlock
                    Margin="0,4,0,0"
                    Text="{x:Bind ViewModel.BuildDescription, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.BuildVisibility, Mode=OneWay}"
                    Style="{ThemeResource BodyTextBlockStyle}" />

                <TextBlock
                    x:Uid="Settings_AboutDescription"
                    Margin="{StaticResource XSmallTopMargin}"
                    Style="{ThemeResource BodyTextBlockStyle}" />
                <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink" Margin="{StaticResource SettingsPageHyperlinkButtonMargin}" />
            </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
