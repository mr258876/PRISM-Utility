<Page
    x:Class="PRISM_Utility.Views.ScanPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:helpers="using:PRISM_Utility.Helpers"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled">
        <StackPanel
            x:Name="ContentArea"
            Margin="{StaticResource SmallLeftRightMargin}">
            <StackPanel
                Orientation="Horizontal"
                Spacing="8"
                Margin="{StaticResource SmallTopBottomMargin}">
                <Button x:Uid="Scan_ConnectButton" Command="{x:Bind ViewModel.ConnectDevicesCommand}" />
                <Button x:Uid="Scan_DisconnectButton" Command="{x:Bind ViewModel.DisconnectDevicesCommand}" />
                <Button x:Uid="Scan_StartButton" Command="{x:Bind ViewModel.StartScanCommand}" />
                <Button x:Uid="Scan_StopButton" Command="{x:Bind ViewModel.StopScanCommand}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                <ProgressBar
                    IsIndeterminate="True"
                    Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{x:Bind ViewModel.CurrentPassText, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentLedText, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentDirectionText, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <controls:WrapPanel
                Margin="{StaticResource SmallTopBottomMargin}"
                Orientation="Horizontal"
                HorizontalSpacing="12"
                VerticalSpacing="12">
                <Border
                    Width="460"
                    MinWidth="380"
                    MaxWidth="520"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Scan_SetupTitle.Text" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ComboBox
                                x:Uid="Scan_RowsComboBox"
                                ItemsSource="{x:Bind ViewModel.RowOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedRows, Mode=TwoWay}" />
                            <ComboBox
                                x:Uid="Scan_ScanMotorComboBox"
                                ItemsSource="{x:Bind ViewModel.MotorOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedScanMotor, Mode=TwoWay}" />
                            <TextBox
                                x:Uid="Scan_MotorIntervalTextBox"
                                Text="{x:Bind ViewModel.MotorIntervalUs, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Uid="Scan_WarmUpToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsWarmUpEnabled, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Uid="Scan_PreviewToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsPreviewEnabled, Mode=TwoWay}" />
                            <ToggleSwitch
                                x:Uid="Scan_AlternateDirectionToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsAlternateMotorDirectionEnabled, Mode=TwoWay}" />
                            <ComboBox
                                x:Uid="Scan_StartingDirectionComboBox"
                                ItemsSource="{x:Bind ViewModel.DirectionOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedStartingDirection, Mode=TwoWay}" />
                            <TextBlock x:Uid="Scan_DirectionHelpText.Text" Opacity="0.8" TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{x:Bind ViewModel.ComputedMotorSummaryText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Scan_PassPlanTitle.Text" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" x:Uid="Scan_PassHeader.Text" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Uid="Scan_LedHeader.Text" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Grid.Row="0" Grid.Column="2" x:Uid="Scan_DirectionHeader.Text" Style="{ThemeResource BodyStrongTextBlockStyle}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Pass 1" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="LED1" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Bind ViewModel.Pass1DirectionText, Mode=OneWay}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Pass 2" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="LED2" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="{x:Bind ViewModel.Pass2DirectionText, Mode=OneWay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Pass 3" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="LED3" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{x:Bind ViewModel.Pass3DirectionText, Mode=OneWay}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Pass 4" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="LED4" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{x:Bind ViewModel.Pass4DirectionText, Mode=OneWay}" />
                            </Grid>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0" Grid.Column="0" x:Uid="Scan_Led1LevelTextBox" Text="{x:Bind ViewModel.Led1Level, Mode=TwoWay}" />
                                <TextBox Grid.Row="0" Grid.Column="1" x:Uid="Scan_Led2LevelTextBox" Text="{x:Bind ViewModel.Led2Level, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.Column="0" x:Uid="Scan_Led3LevelTextBox" Text="{x:Bind ViewModel.Led3Level, Mode=TwoWay}" />
                                <TextBox Grid.Row="1" Grid.Column="1" x:Uid="Scan_Led4LevelTextBox" Text="{x:Bind ViewModel.Led4Level, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Scan_ChannelMappingTitle.Text" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Uid="Scan_ChannelMappingHelpText.Text" Opacity="0.8" TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" x:Uid="Scan_Channel1Label.Text" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{x:Bind ViewModel.ChannelRoleOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedChannel1Role, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Row="0" Grid.Column="2" x:Uid="Scan_Channel1ReverseToggleSwitch" IsOn="{x:Bind ViewModel.IsChannel1Reversed, Mode=TwoWay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" x:Uid="Scan_Channel2Label.Text" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{x:Bind ViewModel.ChannelRoleOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedChannel2Role, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Row="1" Grid.Column="2" x:Uid="Scan_Channel2ReverseToggleSwitch" IsOn="{x:Bind ViewModel.IsChannel2Reversed, Mode=TwoWay}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" x:Uid="Scan_Channel3Label.Text" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{x:Bind ViewModel.ChannelRoleOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedChannel3Role, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Row="2" Grid.Column="2" x:Uid="Scan_Channel3ReverseToggleSwitch" IsOn="{x:Bind ViewModel.IsChannel3Reversed, Mode=TwoWay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" x:Uid="Scan_Channel4Label.Text" VerticalAlignment="Center" />
                                <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{x:Bind ViewModel.ChannelRoleOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedChannel4Role, Mode=TwoWay}" />
                                <ToggleSwitch Grid.Row="3" Grid.Column="2" x:Uid="Scan_Channel4ReverseToggleSwitch" IsOn="{x:Bind ViewModel.IsChannel4Reversed, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="Scan_OutputTitle.Text" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Uid="Scan_SaveRgbImageButton" Command="{x:Bind ViewModel.SaveRgbImageCommand}" />
                                <Button x:Uid="Scan_ExportRawChannelsButton" Command="{x:Bind ViewModel.ExportRawChannelsCommand}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.OutputSummaryText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Width="760"
                    MinWidth="420"
                    MaxWidth="900"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Scan_PreviewTitle.Text" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ComboBox
                                x:Uid="Scan_PreviewModeComboBox"
                                Width="220"
                                ItemsSource="{x:Bind ViewModel.PreviewModes, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedPreviewMode, Mode=TwoWay}" />
                            <TextBlock Text="{x:Bind ViewModel.ChannelMappingSummaryText, Mode=OneWay}" VerticalAlignment="Center" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.PreviewDescriptionText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />

                        <Border
                            Height="520"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="12">
                            <Grid>
                                <Image Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}" Stretch="Uniform" />
                            </Grid>
                        </Border>
                        <TextBlock x:Uid="Scan_PreviewPlaceholderTitle.Text" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.PreviewPlaceholderText, Mode=OneWay}" TextWrapping="WrapWholeWords" />

                        <StackPanel Spacing="6">
                            <TextBlock x:Uid="Scan_RunDetailsTitle.Text" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentPassText, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentLedText, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.CurrentDirectionText, Mode=OneWay}" />
                            <TextBlock Text="{x:Bind ViewModel.OutputSummaryText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </controls:WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
