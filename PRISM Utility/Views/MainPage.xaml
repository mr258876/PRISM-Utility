<Page
    x:Class="PRISM_Utility.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        VerticalScrollMode="Auto"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled">
        <StackPanel
            x:Name="ContentArea"
            Margin="{StaticResource SmallLeftRightMargin}"
            Spacing="12">
            <TextBlock
                x:Uid="Main_PageTitle"
                Margin="{StaticResource SmallTopBottomMargin}"
                Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock
                x:Uid="Main_PageDescription"
                Opacity="0.8"
                TextWrapping="WrapWholeWords" />

            <controls:WrapPanel
                Orientation="Horizontal"
                HorizontalSpacing="12"
                VerticalSpacing="12">
                <Border
                    Width="260"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="Main_StatusConnectionTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Main_StatusConnectionText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <Border
                    Width="260"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="Main_StatusConfigTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Main_StatusConfigText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
                <Border
                    Width="260"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="Main_StatusExportTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Main_StatusExportText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </controls:WrapPanel>

            <TextBlock x:Uid="Main_WorkflowsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <controls:WrapPanel
                Orientation="Horizontal"
                HorizontalSpacing="12"
                VerticalSpacing="12">
                <Border
                    Width="260"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="Main_ScanCardTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Main_ScanCardText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        <Button
                            x:Uid="Main_OpenScanButton"
                            Command="{x:Bind ViewModel.NavigateToScanCommand}" />
                    </StackPanel>
                </Border>
                <Border
                    Width="260"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="Main_ScanDebugCardTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Main_ScanDebugCardText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        <Button
                            x:Uid="Main_OpenScanDebugButton"
                            Command="{x:Bind ViewModel.NavigateToScanDebugCommand}" />
                    </StackPanel>
                </Border>
                <Border
                    Width="260"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Uid="Main_SettingsCardTitle" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Uid="Main_SettingsCardText" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        <Button
                            x:Uid="Main_OpenSettingsButton"
                            Command="{x:Bind ViewModel.NavigateToSettingsCommand}" />
                    </StackPanel>
                </Border>
            </controls:WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
