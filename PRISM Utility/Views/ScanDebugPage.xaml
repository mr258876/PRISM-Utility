<Page
    x:Class="PRISM_Utility.Views.ScanDebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:helpers="using:PRISM_Utility.Helpers"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:ScanSelectorDisplayNameConverter x:Key="ScanSelectorDisplayNameConverter" />
        <DataTemplate x:Key="ScanMotorOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=Motor}" />
        </DataTemplate>
        <DataTemplate x:Key="ScanDirectionOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=Direction}" />
        </DataTemplate>
        <DataTemplate x:Key="ScanCalibrationChannelOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=CalibrationChannel}" />
        </DataTemplate>
        <DataTemplate x:Key="ScanMotorDirectionOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=MotorDirection}" />
        </DataTemplate>
        <DataTemplate x:Key="ScanRoiSelectionOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=RoiSelection}" />
        </DataTemplate>
        <DataTemplate x:Key="ScanChannelRoleOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=ChannelRole}" />
        </DataTemplate>
    </Page.Resources>
    <Grid
        Margin="{StaticResource SmallLeftRightMargin}"
        RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="{StaticResource SmallTopBottomMargin}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Padding="12">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    TextWrapping="WrapWholeWords" />
                <ProgressBar
                    IsIndeterminate="False"
                    Maximum="{x:Bind ViewModel.ScanReadProgressMaximum, Mode=OneWay}"
                    Value="{x:Bind ViewModel.ScanReadProgressValue, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.ScanReadProgressVisibility, Mode=OneWay}" />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="{StaticResource SmallTopBottomMargin}"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="12">
                <ScrollViewer
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Disabled">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="ScanDebug_AcquisitionTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_ConnectButton" Command="{x:Bind ViewModel.ConnectDevicesCommand}" />
                                <Button Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_DisconnectButton" Command="{x:Bind ViewModel.DisconnectDevicesCommand}" />
                                <Button Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_StartButton" Command="{x:Bind ViewModel.StartScanCommand}" />
                                <Button Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_StopButton" Command="{x:Bind ViewModel.StopScanCommand}" />
                                <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Uid="ScanDebug_ExportDngButton" Command="{x:Bind ViewModel.ExportDngCommand}" />
                                <ComboBox
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_RowsComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsEditable="True"
                                    ItemsSource="{x:Bind ViewModel.RowOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedRows, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    x:Uid="Scan_ScanMotorComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.MotorOptions, Mode=OneWay}"
                                    ItemTemplate="{StaticResource ScanMotorOptionTemplate}"
                                    SelectedItem="{x:Bind ViewModel.SelectedScanMotor, Mode=TwoWay}" />
                                <Grid
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        Grid.Column="0"
                                        x:Uid="Scan_MotorIntervalTextBox"
                                        IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                        Text="{x:Bind ViewModel.MotorDistancePerLineValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox
                                        Grid.Column="1"
                                        x:Uid="Scan_MotorIntervalUnitComboBox"
                                        IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                        ItemsSource="{x:Bind ViewModel.MotorDistancePerLineUnitOptions, Mode=OneWay}"
                                        SelectedItem="{x:Bind ViewModel.MotorDistancePerLineUnit, Mode=TwoWay}" />
                                </Grid>
                                <ToggleSwitch
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    x:Uid="ScanDebug_WarmUpToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsWarmUpEnabled, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Grid.Row="5"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_PreviewToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.IsPreviewToggleEnabled, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsPreviewEnabled, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Grid.Row="5"
                                    Grid.Column="1"
                                    x:Uid="Scan_AlternateDirectionToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsAlternateMotorDirectionEnabled, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Row="6"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    x:Uid="Scan_StartingDirectionComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.DirectionOptions, Mode=OneWay}"
                                    ItemTemplate="{StaticResource ScanDirectionOptionTemplate}"
                                    SelectedItem="{x:Bind ViewModel.SelectedStartingDirection, Mode=TwoWay}" />
                                <TextBlock
                                    Grid.Row="7"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Text="{x:Bind ViewModel.ComputedMotorSummaryText, Mode=OneWay}"
                                    Opacity="0.8"
                                    TextWrapping="WrapWholeWords" />
                                <ToggleSwitch
                                    Grid.Row="8"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_ContinuousToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsContinuousScanEnabled, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Grid.Row="8"
                                    Grid.Column="1"
                                    x:Uid="ScanDebug_WaterfallToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsWaterfallEnabled, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Grid.Row="9"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_MultiChannelToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsMultiChannelScanEnabled, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Grid.Row="9"
                                    Grid.Column="1"
                                    x:Uid="ScanDebug_ScanMotorTransportToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsScanMotorTransportEnabled, Mode=TwoWay}" />
                                <ToggleSwitch
                                    Grid.Row="10"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    x:Uid="ScanDebug_ScanLedAutoControlToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsScanLedAutoControlEnabled, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock x:Uid="ScanDebug_ParamsTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <TextBlock x:Uid="ScanDebug_ExposureFormulaNote" Opacity="0.8" TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_FilmProfileNameTextBox"
                                    Text="{x:Bind ViewModel.FilmProfileName, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    x:Uid="ScanDebug_CalibrationChannelComboBox"
                                    ItemsSource="{x:Bind ViewModel.CalibrationChannelOptions, Mode=OneWay}"
                                    ItemTemplate="{StaticResource ScanCalibrationChannelOptionTemplate}"
                                    SelectedItem="{x:Bind ViewModel.SelectedCalibrationChannel, Mode=TwoWay}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Text="{x:Bind ViewModel.CalibrationChannelStatusText, Mode=OneWay}"
                                    Opacity="0.8"
                                    TextWrapping="WrapWholeWords" />
                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_SaveChannelButton" Command="{x:Bind ViewModel.SaveChannelProfileCommand}" />
                                    <Button Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_ClearChannelButton" Command="{x:Bind ViewModel.ClearChannelProfileCommand}" />
                                    <Button Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_SaveJsonButton" Command="{x:Bind ViewModel.SaveFilmProfileJsonCommand}" />
                                    <Button Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_LoadJsonButton" Command="{x:Bind ViewModel.LoadFilmProfileJsonCommand}" />
                                </Grid>
                            </Grid>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBox
                                        x:Uid="ScanDebug_ExposureTextBox"
                                        Text="{x:Bind ViewModel.ExposureTicks, Mode=TwoWay}" />
                                    <TextBlock
                                        Text="{x:Bind ViewModel.ExposureTimeDisplay, Mode=OneWay}"
                                        Opacity="0.8"
                                        TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBox
                                        x:Uid="ScanDebug_Adc1OffsetTextBox"
                                        Text="{x:Bind ViewModel.Adc1Offset, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.Adc1OffsetLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.Adc1OffsetLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                    <TextBlock Text="{x:Bind ViewModel.Adc1OffsetMvDisplay, Mode=OneWay}" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBox
                                        x:Uid="ScanDebug_Adc1GainTextBox"
                                        Text="{x:Bind ViewModel.Adc1Gain, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.Adc1GainLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.Adc1GainLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                    <TextBlock Text="{x:Bind ViewModel.Adc1GainVvDisplay, Mode=OneWay}" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBox
                                        x:Uid="ScanDebug_Adc2OffsetTextBox"
                                        Text="{x:Bind ViewModel.Adc2Offset, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.Adc2OffsetLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.Adc2OffsetLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                    <TextBlock Text="{x:Bind ViewModel.Adc2OffsetMvDisplay, Mode=OneWay}" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                    <TextBox
                                        x:Uid="ScanDebug_Adc2GainTextBox"
                                        Text="{x:Bind ViewModel.Adc2Gain, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.Adc2GainLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.Adc2GainLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                    <TextBlock Text="{x:Bind ViewModel.Adc2GainVvDisplay, Mode=OneWay}" Opacity="0.8" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                    <TextBox
                                        x:Uid="ScanDebug_SysClockKhzTextBox"
                                        Text="{x:Bind ViewModel.SysClockKhz, Mode=TwoWay}" />
                                    <TextBlock Text="{x:Bind ViewModel.SysClockMhzDisplay, Mode=OneWay}" Opacity="0.8" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_ApplyParamsButton" Command="{x:Bind ViewModel.ApplyParametersCommand}" />
                                <Button Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_AutoBlackButton" Command="{x:Bind ViewModel.AutoBlackAdjustCommand}" />
                                <Button Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_AutoWhiteButton" Command="{x:Bind ViewModel.AutoWhiteAdjustCommand}" />
                                <Button Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_AutoCalibrateButton" Command="{x:Bind ViewModel.AutoCalibrateCommand}" />
                            </Grid>
                        </StackPanel>

                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <TextBlock x:Uid="ScanDebug_AutofocusTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            </Expander.Header>
                            <StackPanel Margin="{StaticResource XSmallTopMargin}" Spacing="8">
                                <TextBlock x:Uid="ScanDebug_AutofocusNote" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.AutofocusSummaryText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBox x:Uid="ScanDebug_AutofocusSampleRowsTextBox" Text="{x:Bind ViewModel.AutofocusSampleRows, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.AutofocusSampleRowsLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.AutofocusSampleRowsLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBox x:Uid="ScanDebug_AutofocusTiltProbeStepsTextBox" Text="{x:Bind ViewModel.AutofocusTiltProbeSteps, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.AutofocusTiltProbeStepsLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.AutofocusTiltProbeStepsLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBox x:Uid="ScanDebug_AutofocusZProbeStepsTextBox" Text="{x:Bind ViewModel.AutofocusZProbeSteps, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.AutofocusZProbeStepsLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.AutofocusZProbeStepsLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBox x:Uid="ScanDebug_AutofocusMotorIntervalUsTextBox" Text="{x:Bind ViewModel.AutofocusMotorIntervalUs, Mode=TwoWay}" />
                                    <Border
                                        Padding="8,4"
                                        CornerRadius="6"
                                        Background="{x:Bind ViewModel.AutofocusMotorIntervalLimitBrush, Mode=OneWay}">
                                        <TextBlock
                                            Text="{x:Bind ViewModel.AutofocusMotorIntervalLimitText, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords"
                                            FontSize="12" />
                                    </Border>
                                </StackPanel>

                                <ComboBox Grid.Row="2" Grid.Column="0" x:Uid="ScanDebug_AutofocusZDirectionComboBox" ItemsSource="{x:Bind ViewModel.MotorDirectionOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanMotorDirectionOptionTemplate}" SelectedItem="{x:Bind ViewModel.AutofocusZDirection, Mode=TwoWay}" />
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Uid="ScanDebug_AutofocusTiltDirectionComboBox" ItemsSource="{x:Bind ViewModel.MotorDirectionOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanMotorDirectionOptionTemplate}" SelectedItem="{x:Bind ViewModel.AutofocusTiltDirection, Mode=TwoWay}" />
                                <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Uid="ScanDebug_RunAutofocusButton" Command="{x:Bind ViewModel.AutoFocusCommand}" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <TextBlock x:Uid="ScanDebug_IlluminationTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            </Expander.Header>
                            <StackPanel Margin="{StaticResource XSmallTopMargin}" Spacing="8">
                                <TextBlock x:Uid="ScanDebug_IlluminationNote" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                <TextBlock Text="{x:Bind ViewModel.IlluminationSummaryText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Uid="ScanDebug_Led1Channel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <ComboBox ItemsSource="{x:Bind ViewModel.ChannelColorOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanChannelRoleOptionTemplate}" SelectedItem="{x:Bind ViewModel.SelectedLed1ChannelColor, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led1LevelTextBox" Text="{x:Bind ViewModel.Led1Level, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led1PulseTextBox" Text="{x:Bind ViewModel.Led1PulseClock, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led1SteadyCheckBox" IsChecked="{x:Bind ViewModel.IsLed1SteadyEnabled, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led1SyncCheckBox" IsChecked="{x:Bind ViewModel.IsLed1SyncEnabled, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="0" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Uid="ScanDebug_Led2Channel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <ComboBox ItemsSource="{x:Bind ViewModel.ChannelColorOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanChannelRoleOptionTemplate}" SelectedItem="{x:Bind ViewModel.SelectedLed2ChannelColor, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led2LevelTextBox" Text="{x:Bind ViewModel.Led2Level, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led2PulseTextBox" Text="{x:Bind ViewModel.Led2PulseClock, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led2SteadyCheckBox" IsChecked="{x:Bind ViewModel.IsLed2SteadyEnabled, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led2SyncCheckBox" IsChecked="{x:Bind ViewModel.IsLed2SyncEnabled, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Uid="ScanDebug_Led3Channel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <ComboBox ItemsSource="{x:Bind ViewModel.ChannelColorOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanChannelRoleOptionTemplate}" SelectedItem="{x:Bind ViewModel.SelectedLed3ChannelColor, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led3LevelTextBox" Text="{x:Bind ViewModel.Led3Level, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led3PulseTextBox" Text="{x:Bind ViewModel.Led3PulseClock, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led3SteadyCheckBox" IsChecked="{x:Bind ViewModel.IsLed3SteadyEnabled, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led3SyncCheckBox" IsChecked="{x:Bind ViewModel.IsLed3SyncEnabled, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Uid="ScanDebug_Led4Channel" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <ComboBox ItemsSource="{x:Bind ViewModel.ChannelColorOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanChannelRoleOptionTemplate}" SelectedItem="{x:Bind ViewModel.SelectedLed4ChannelColor, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led4LevelTextBox" Text="{x:Bind ViewModel.Led4Level, Mode=TwoWay}" />
                                        <TextBox x:Uid="ScanDebug_Led4PulseTextBox" Text="{x:Bind ViewModel.Led4PulseClock, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led4SteadyCheckBox" IsChecked="{x:Bind ViewModel.IsLed4SteadyEnabled, Mode=TwoWay}" />
                                        <CheckBox x:Uid="ScanDebug_Led4SyncCheckBox" IsChecked="{x:Bind ViewModel.IsLed4SyncEnabled, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" x:Uid="ScanDebug_RefreshIlluminationButton" Command="{x:Bind ViewModel.RefreshIlluminationCommand}" />
                                    <Button Grid.Column="1" x:Uid="ScanDebug_ApplyIlluminationButton" Command="{x:Bind ViewModel.ApplyIlluminationCommand}" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <TextBlock x:Uid="ScanDebug_MotionTitle" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            </Expander.Header>
                            <StackPanel Margin="{StaticResource XSmallTopMargin}" Spacing="8">
                                <TextBlock x:Uid="ScanDebug_MotionNote" Opacity="0.8" TextWrapping="WrapWholeWords" />
                                <Button x:Uid="ScanDebug_RefreshMotionButton" Command="{x:Bind ViewModel.RefreshMotionCommand}" />
                                <TextBlock Text="{x:Bind ViewModel.MotionSummaryText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />

                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Uid="ScanDebug_Motor1Title" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.Motor1StatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <Grid ColumnSpacing="8">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*" />
                                         <ColumnDefinition Width="*" />
                                     </Grid.ColumnDefinitions>
                                     <Button Grid.Column="0" x:Uid="ScanDebug_Motor1EnableButton" Command="{x:Bind ViewModel.EnableMotorCommand}" CommandParameter="1" />
                                     <Button Grid.Column="1" x:Uid="ScanDebug_Motor1DisableButton" Command="{x:Bind ViewModel.DisableMotorCommand}" CommandParameter="1" />
                                     </Grid>
                                     <ComboBox ItemsSource="{x:Bind ViewModel.MotorDirectionOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanMotorDirectionOptionTemplate}" SelectedItem="{x:Bind ViewModel.Motor1MoveDirection, Mode=TwoWay}" />
                                    <Grid ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_Motor1MoveValueTextBox" Text="{x:Bind ViewModel.Motor1MoveValue, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_Motor1MoveUnitComboBox" ItemsSource="{x:Bind ViewModel.MotorUnitOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Motor1MoveUnit, Mode=TwoWay}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_Motor1SpeedValueTextBox" Text="{x:Bind ViewModel.Motor1SpeedValue, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_Motor1SpeedUnitComboBox" ItemsSource="{x:Bind ViewModel.MotorUnitOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Motor1SpeedUnit, Mode=TwoWay}" />
                                    </Grid>
                                     <Grid ColumnSpacing="8" RowSpacing="8">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_Motor1MoveButton" Command="{x:Bind ViewModel.MoveMotorCommand}" CommandParameter="1" />
                                        <Button Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_Motor1StopButton" Command="{x:Bind ViewModel.StopMotorCommand}" CommandParameter="1" />
                                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Uid="ScanDebug_Motor1ApplyConfigButton" Command="{x:Bind ViewModel.ApplyMotorConfigCommand}" CommandParameter="1" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Uid="ScanDebug_Motor2Title" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.Motor2StatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <Grid ColumnSpacing="8">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*" />
                                         <ColumnDefinition Width="*" />
                                     </Grid.ColumnDefinitions>
                                     <Button Grid.Column="0" x:Uid="ScanDebug_Motor2EnableButton" Command="{x:Bind ViewModel.EnableMotorCommand}" CommandParameter="2" />
                                     <Button Grid.Column="1" x:Uid="ScanDebug_Motor2DisableButton" Command="{x:Bind ViewModel.DisableMotorCommand}" CommandParameter="2" />
                                     </Grid>
                                     <ComboBox ItemsSource="{x:Bind ViewModel.MotorDirectionOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanMotorDirectionOptionTemplate}" SelectedItem="{x:Bind ViewModel.Motor2MoveDirection, Mode=TwoWay}" />
                                    <Grid ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_Motor2MoveValueTextBox" Text="{x:Bind ViewModel.Motor2MoveValue, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_Motor2MoveUnitComboBox" ItemsSource="{x:Bind ViewModel.MotorUnitOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Motor2MoveUnit, Mode=TwoWay}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_Motor2SpeedValueTextBox" Text="{x:Bind ViewModel.Motor2SpeedValue, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_Motor2SpeedUnitComboBox" ItemsSource="{x:Bind ViewModel.MotorUnitOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Motor2SpeedUnit, Mode=TwoWay}" />
                                    </Grid>
                                     <Grid ColumnSpacing="8" RowSpacing="8">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_Motor2MoveButton" Command="{x:Bind ViewModel.MoveMotorCommand}" CommandParameter="2" />
                                        <Button Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_Motor2StopButton" Command="{x:Bind ViewModel.StopMotorCommand}" CommandParameter="2" />
                                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Uid="ScanDebug_Motor2ApplyConfigButton" Command="{x:Bind ViewModel.ApplyMotorConfigCommand}" CommandParameter="2" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Padding="8">
                                <StackPanel Spacing="6">
                                    <TextBlock x:Uid="ScanDebug_Motor3Title" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind ViewModel.Motor3StatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    <Grid ColumnSpacing="8">
                                     <Grid.ColumnDefinitions>
                                         <ColumnDefinition Width="*" />
                                         <ColumnDefinition Width="*" />
                                     </Grid.ColumnDefinitions>
                                     <Button Grid.Column="0" x:Uid="ScanDebug_Motor3EnableButton" Command="{x:Bind ViewModel.EnableMotorCommand}" CommandParameter="3" />
                                     <Button Grid.Column="1" x:Uid="ScanDebug_Motor3DisableButton" Command="{x:Bind ViewModel.DisableMotorCommand}" CommandParameter="3" />
                                     </Grid>
                                     <ComboBox ItemsSource="{x:Bind ViewModel.MotorDirectionOptions, Mode=OneWay}" ItemTemplate="{StaticResource ScanMotorDirectionOptionTemplate}" SelectedItem="{x:Bind ViewModel.Motor3MoveDirection, Mode=TwoWay}" />
                                    <Grid ColumnSpacing="8" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_Motor3MoveValueTextBox" Text="{x:Bind ViewModel.Motor3MoveValue, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_Motor3MoveUnitComboBox" ItemsSource="{x:Bind ViewModel.MotorUnitOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Motor3MoveUnit, Mode=TwoWay}" />
                                        <TextBox Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_Motor3SpeedValueTextBox" Text="{x:Bind ViewModel.Motor3SpeedValue, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_Motor3SpeedUnitComboBox" ItemsSource="{x:Bind ViewModel.MotorUnitOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.Motor3SpeedUnit, Mode=TwoWay}" />
                                    </Grid>
                                     <Grid ColumnSpacing="8" RowSpacing="8">
                                         <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*" />
                                             <ColumnDefinition Width="*" />
                                         </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_Motor3MoveButton" Command="{x:Bind ViewModel.MoveMotorCommand}" CommandParameter="3" />
                                        <Button Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_Motor3StopButton" Command="{x:Bind ViewModel.StopMotorCommand}" CommandParameter="3" />
                                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Uid="ScanDebug_Motor3ApplyConfigButton" Command="{x:Bind ViewModel.ApplyMotorConfigCommand}" CommandParameter="3" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border
                Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="12">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Uid="ScanDebug_Preview" Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <Expander Grid.Row="1" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock x:Uid="ScanDebug_OverlayToolsHeader" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        </Expander.Header>
                        <StackPanel Margin="{StaticResource XSmallTopMargin}" Spacing="8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleSwitch
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_RoiEditToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.CanEditRoiSelection, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsRoiEditModeEnabled, Mode=TwoWay}" />
                                <ComboBox
                                    Grid.Column="1"
                                    x:Uid="ScanDebug_RoiTargetComboBox"
                                    ItemsSource="{x:Bind ViewModel.RoiSelectionOptions, Mode=OneWay}"
                                    ItemTemplate="{StaticResource ScanRoiSelectionOptionTemplate}"
                                    SelectedItem="{x:Bind ViewModel.SelectedRoiSelection, Mode=TwoWay}" />
                            </Grid>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" x:Uid="ScanDebug_ResetSelectedRoiButton" Command="{x:Bind ViewModel.ResetSelectedRoiCommand}" />
                                <Button Grid.Column="1" x:Uid="ScanDebug_ResetAllRoisButton" Command="{x:Bind ViewModel.ResetAllRoisCommand}" />
                            </Grid>
                            <TextBlock x:Uid="ScanDebug_VisibleOverlaysText" Opacity="0.8" />
                            <Grid ColumnSpacing="12" RowSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0" x:Uid="ScanDebug_BwActiveOverlayCheckBox" IsChecked="{x:Bind ViewModel.IsBwActiveRoiOverlayVisible, Mode=TwoWay}" />
                                <CheckBox Grid.Row="0" Grid.Column="1" x:Uid="ScanDebug_BwShieldOverlayCheckBox" IsChecked="{x:Bind ViewModel.IsBwShieldRoiOverlayVisible, Mode=TwoWay}" />
                                <CheckBox Grid.Row="0" Grid.Column="2" x:Uid="ScanDebug_FocusOverallOverlayCheckBox" IsChecked="{x:Bind ViewModel.IsFocusOverallRoiOverlayVisible, Mode=TwoWay}" />
                                <CheckBox Grid.Row="1" Grid.Column="0" x:Uid="ScanDebug_FocusLeftOverlayCheckBox" IsChecked="{x:Bind ViewModel.IsFocusLeftRoiOverlayVisible, Mode=TwoWay}" />
                                <CheckBox Grid.Row="1" Grid.Column="1" x:Uid="ScanDebug_FocusRightOverlayCheckBox" IsChecked="{x:Bind ViewModel.IsFocusRightRoiOverlayVisible, Mode=TwoWay}" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.RoiStatusText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Uid="ScanDebug_RoiStartTextBox" Text="{x:Bind ViewModel.RoiStartInput, Mode=TwoWay}" />
                                <TextBox Grid.Column="1" x:Uid="ScanDebug_RoiEndTextBox" Text="{x:Bind ViewModel.RoiEndInput, Mode=TwoWay}" />
                                <Button Grid.Column="2" x:Uid="ScanDebug_ApplyRoiButton" VerticalAlignment="Bottom" Command="{x:Bind ViewModel.ApplySelectedRoiInputsCommand}" />
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.RoiInputStatusText, Mode=OneWay}" Opacity="0.8" TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Expander>

                    <StackPanel Grid.Row="2" Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ToggleSwitch
                                Grid.Column="0"
                                x:Uid="ScanDebug_GammaCorrectionToggleSwitch"
                                IsOn="{x:Bind ViewModel.IsGammaCorrectionEnabled, Mode=TwoWay}" />
                            <ToggleSwitch
                                Grid.Column="1"
                                x:Uid="ScanDebug_WaterfallCompressionToggleSwitch"
                                IsEnabled="{x:Bind ViewModel.IsWaterfallEnabled, Mode=OneWay}"
                                IsOn="{x:Bind ViewModel.IsWaterfallCompressedEnabled, Mode=TwoWay}" />
                            <TextBox
                                Grid.Column="2"
                                x:Uid="ScanDebug_GammaTextBox"
                                Width="120"
                                IsEnabled="{x:Bind ViewModel.IsGammaCorrectionEnabled, Mode=OneWay}"
                                Text="{x:Bind ViewModel.PreviewGamma, Mode=TwoWay}" />
                        </Grid>
                        <ToggleSwitch
                            Header="Use saved white level in preview"
                            IsOn="{x:Bind ViewModel.IsWhiteLevelPreviewEnabled, Mode=TwoWay}" />
                        <ToggleSwitch
                            Header="Edit column sample selection"
                            IsEnabled="{x:Bind ViewModel.CanEditColumnSampleSelection, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.IsColumnSampleEditModeEnabled, Mode=TwoWay}" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Save columns as black level" Command="{x:Bind ViewModel.SaveColumnSampleAsBlackLevelCommand}" />
                            <Button Grid.Column="1" Content="Save columns as white level" Command="{x:Bind ViewModel.SaveColumnSampleAsWhiteLevelCommand}" />
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.ColumnSampleStatusText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <Border
                        Grid.Row="3"
                        MinHeight="360"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Padding="8">
                        <ScrollViewer
                            x:Name="PreviewScrollViewer"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            VerticalScrollMode="Enabled"
                            ZoomMode="Enabled"
                            MinZoomFactor="0.1"
                            MaxZoomFactor="20"
                            SizeChanged="PreviewScrollViewer_SizeChanged"
                            ViewChanged="PreviewScrollViewer_ViewChanged"
                            PointerPressed="PreviewScrollViewer_PointerPressed"
                            PointerMoved="PreviewScrollViewer_PointerMoved"
                            PointerReleased="PreviewScrollViewer_PointerReleased"
                            PointerCanceled="PreviewScrollViewer_PointerCanceled"
                            PointerWheelChanged="PreviewScrollViewer_PointerWheelChanged">
                            <Canvas x:Name="PreviewCanvas">
                                <canvas:CanvasControl
                                    x:Name="PreviewCanvasControl"
                                    ClearColor="Transparent"
                                    CreateResources="PreviewCanvasControl_CreateResources"
                                    Draw="PreviewCanvasControl_Draw"
                                    PointerPressed="PreviewCanvasControl_PointerPressed"
                                    PointerMoved="PreviewCanvasControl_PointerMoved"
                                    PointerReleased="PreviewCanvasControl_PointerReleased"
                                    PointerCanceled="PreviewCanvasControl_PointerCanceled"
                                    PointerExited="PreviewCanvasControl_PointerExited" />
                                <Canvas x:Name="RoiCanvas" IsHitTestVisible="False" />
                                <Canvas x:Name="AxisCanvas" IsHitTestVisible="False" />
                            </Canvas>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock x:Name="CursorPositionTextBlock" />
                                    <TextBlock x:Name="CursorIntensityTextBlock" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="-" Click="ZoomOutButton_Click" />
                            <Button Content="+" Click="ZoomInButton_Click" />
                            <ComboBox
                                x:Name="ZoomScaleComboBox"
                                Width="120"
                                SelectionChanged="ZoomScaleComboBox_SelectionChanged" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
