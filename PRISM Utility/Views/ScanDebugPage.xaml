<Page
    x:Class="PRISM_Utility.Views.ScanDebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    xmlns:behaviors="using:PRISM_Utility.Behaviors"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:helpers="using:PRISM_Utility.Helpers"
    behaviors:NavigationViewHeaderBehavior.HeaderMode="Never"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">
    <Page.Resources>
        <helpers:ScanSelectorDisplayNameConverter x:Key="ScanSelectorDisplayNameConverter"/>
        <Thickness x:Key="ScanDebugPagePadding">12,12,12,24</Thickness>
        <Thickness x:Key="ScanDebugCardPadding">12</Thickness>
        <Thickness x:Key="ScanDebugHeaderMargin">0,0,0,12</Thickness>
        <Thickness x:Key="ScanDebugPreviewPadding">0</Thickness>
        <Thickness x:Key="ScanDebugCardBorderThickness">1</Thickness>
        <CornerRadius x:Key="ScanDebugCardCornerRadius">8</CornerRadius>
        <x:Double x:Key="ScanDebugInlineSpacing">8</x:Double>
        <x:Double x:Key="ScanDebugSectionSpacing">12</x:Double>
        <x:Double x:Key="ScanDebugPreviewMinimumHeight">360</x:Double>
        <DataTemplate x:Key="ScanMotorOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=Motor}"/>
        </DataTemplate>
        <DataTemplate x:Key="ScanDirectionOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=Direction}"/>
        </DataTemplate>
        <DataTemplate x:Key="ScanCalibrationChannelOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=CalibrationChannel}"/>
        </DataTemplate>
        <DataTemplate x:Key="ScanMotorDirectionOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=MotorDirection}"/>
        </DataTemplate>
        <DataTemplate x:Key="ScanRoiSelectionOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=RoiSelection}"/>
        </DataTemplate>
        <DataTemplate x:Key="ScanDngExportModeOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=DngExportMode}"/>
        </DataTemplate>
        <DataTemplate x:Key="ScanAlignmentModeOptionTemplate">
            <TextBlock Text="{Binding Converter={StaticResource ScanSelectorDisplayNameConverter}, ConverterParameter=AlignmentMode}"/>
        </DataTemplate>
        <Style x:Key="ScanDebugSectionCardStyle"
               TargetType="Border">
            <Setter Property="BorderBrush"
                    Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="{StaticResource ScanDebugCardBorderThickness}"/>
            <Setter Property="CornerRadius"
                    Value="{StaticResource ScanDebugCardCornerRadius}"/>
            <Setter Property="Padding"
                    Value="{StaticResource ScanDebugCardPadding}"/>
            <Setter Property="Background"
                    Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
        </Style>
        <Style x:Key="ScanDebugQuietTextBlockStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="TextWrapping"
                    Value="WrapWholeWords"/>
        </Style>
    </Page.Resources>
    <Grid
        Margin="{StaticResource ScanDebugPagePadding}"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowSpacing="{StaticResource ScanDebugSectionSpacing}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Margin="{StaticResource ScanDebugHeaderMargin}"
            ColumnSpacing="{StaticResource ScanDebugSectionSpacing}"
            RowSpacing="{StaticResource ScanDebugInlineSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center"
                        Spacing="{StaticResource ScanDebugInlineSpacing}">
                <TextBlock
                    x:Uid="ScanDebug_WorkstationTitle"
                    Style="{ThemeResource TitleTextBlockStyle}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    Style="{StaticResource ScanDebugQuietTextBlockStyle}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Spacing="{StaticResource ScanDebugInlineSpacing}">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="{StaticResource ScanDebugInlineSpacing}">
                    <Button MinWidth="104"
                            x:Uid="ScanDebug_StartButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StartScanCommand}"/>
                    <Button
                        MinWidth="88"
                        x:Uid="ScanDebug_StopButton"
                        BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                        Command="{x:Bind ViewModel.StopScanCommand}"
                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="{StaticResource ScanDebugInlineSpacing}">
                    <ComboBox
                        Width="260"
                        x:Uid="ScanDebug_DebugDngExportModeComboBox"
                        ItemsSource="{x:Bind ViewModel.DngExportModeOptions, Mode=OneWay}"
                        ItemTemplate="{StaticResource ScanDngExportModeOptionTemplate}"
                        SelectedItem="{x:Bind ViewModel.SelectedDebugDngExportMode, Mode=TwoWay}"
                        VerticalAlignment="Center"/>
                    <Button MinWidth="104"
                            x:Uid="ScanDebug_ExportDngButton"
                            Command="{x:Bind ViewModel.ExportDngCommand}"/>
                </StackPanel>
            </StackPanel>

            <ProgressBar
                Grid.Row="1"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Stretch"
                IsIndeterminate="False"
                Maximum="{x:Bind ViewModel.ScanReadProgressMaximum, Mode=OneWay}"
                Value="{x:Bind ViewModel.ScanReadProgressValue, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.ScanReadProgressVisibility, Mode=OneWay}"/>
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnSpacing="{StaticResource ScanDebugSectionSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer
                Grid.Column="0"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled">
                <StackPanel Spacing="{StaticResource ScanDebugSectionSpacing}">
                    <Border Style="{StaticResource ScanDebugSectionCardStyle}">
                        <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                            <TextBlock x:Uid="ScanDebug_AcquisitionTitle"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <TextBlock x:Uid="ScanDebug_BasicAcquisitionTitle"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock x:Uid="ScanDebug_BasicAcquisitionScopeText"
                                       Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                            <Grid ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                  RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ComboBox
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_RowsComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsEditable="True"
                                    ItemsSource="{x:Bind ViewModel.RowOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedRows, Mode=TwoWay}"/>
                                <ComboBox
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    x:Uid="Scan_ScanMotorComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.MotorOptions, Mode=OneWay}"
                                    ItemTemplate="{StaticResource ScanMotorOptionTemplate}"
                                    SelectedItem="{x:Bind ViewModel.SelectedScanMotor, Mode=TwoWay}"/>
                                <TextBox
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    x:Uid="Scan_MotorIntervalTextBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.MotorDistancePerLineValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <ComboBox
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    x:Uid="Scan_MotorIntervalUnitComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.MotorDistancePerLineUnitOptions, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.MotorDistancePerLineUnit, Mode=TwoWay}"/>
                                <ToggleSwitch
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    x:Uid="ScanDebug_WarmUpToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsWarmUpEnabled, Mode=TwoWay}"/>
                                <ToggleSwitch
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    x:Uid="ScanDebug_PreviewToggleSwitch"
                                    IsEnabled="{x:Bind ViewModel.IsPreviewToggleEnabled, Mode=OneWay}"
                                    IsOn="{x:Bind ViewModel.IsPreviewEnabled, Mode=TwoWay}"/>
                                <ComboBox
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    x:Uid="Scan_StartingDirectionComboBox"
                                    IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                    ItemsSource="{x:Bind ViewModel.DirectionOptions, Mode=OneWay}"
                                    ItemTemplate="{StaticResource ScanDirectionOptionTemplate}"
                                    SelectedItem="{x:Bind ViewModel.SelectedStartingDirection, Mode=TwoWay}"/>
                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Text="{x:Bind ViewModel.ComputedMotorSummaryText, Mode=OneWay}"
                                    Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                            </Grid>

                            <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                                <TextBlock x:Uid="ScanDebug_AdvancedDebugSwitchesTitle"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Uid="ScanDebug_AdvancedDebugSwitchesScopeText"
                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                <Grid ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                      RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ToggleSwitch
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        x:Uid="ScanDebug_ContinuousToggleSwitch"
                                        IsEnabled="{x:Bind ViewModel.CanEditContinuousScan, Mode=OneWay}"
                                        IsOn="{x:Bind ViewModel.IsContinuousScanEnabled, Mode=TwoWay}"/>
                                    <ToggleSwitch
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        x:Uid="ScanDebug_WaterfallToggleSwitch"
                                        IsEnabled="{x:Bind ViewModel.CanEditWaterfall, Mode=OneWay}"
                                        IsOn="{x:Bind ViewModel.IsWaterfallEnabled, Mode=TwoWay}"/>
                                    <ToggleSwitch
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        x:Uid="ScanDebug_ScanLedAutoControlToggleSwitch"
                                        IsEnabled="{x:Bind ViewModel.CanEditScanLedAutoControl, Mode=OneWay}"
                                        IsOn="{x:Bind ViewModel.IsScanLedAutoControlEnabled, Mode=TwoWay}"/>
                                    <ToggleSwitch
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        x:Uid="ScanDebug_ScanMotorTransportToggleSwitch"
                                        IsEnabled="{x:Bind ViewModel.CanEditScanMotorTransport, Mode=OneWay}"
                                        IsOn="{x:Bind ViewModel.IsScanMotorTransportEnabled, Mode=TwoWay}"/>
                                    <ToggleSwitch
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        x:Uid="ScanDebug_MultiChannelToggleSwitch"
                                        IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                        IsOn="{x:Bind ViewModel.IsMultiChannelScanEnabled, Mode=TwoWay}"/>
                                    <ToggleSwitch
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        x:Uid="Scan_AlternateDirectionToggleSwitch"
                                        IsEnabled="{x:Bind ViewModel.AreScanAcquisitionSettingsEditable, Mode=OneWay}"
                                        IsOn="{x:Bind ViewModel.IsAlternateMotorDirectionEnabled, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ScanDebugSectionCardStyle}">
                        <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                            <TextBlock x:Uid="ScanDebug_ParamsTitle"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                                <TextBlock x:Uid="ScanDebug_ProfileConfigTitle"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <Grid ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                      RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        x:Uid="ScanDebug_FilmProfileNameTextBox"
                                        Text="{x:Bind ViewModel.FilmProfileName, Mode=TwoWay}"/>
                                    <Grid Grid.Row="1"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                          RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Button Grid.Row="0"
                                                Grid.Column="0"
                                                x:Uid="ScanDebug_SaveJsonButton"
                                                Command="{x:Bind ViewModel.SaveFilmProfileJsonCommand}"/>
                                        <Button Grid.Row="0"
                                                Grid.Column="1"
                                                x:Uid="ScanDebug_LoadJsonButton"
                                                Command="{x:Bind ViewModel.LoadFilmProfileJsonCommand}"/>
                                    </Grid>
                                    <ComboBox Grid.Row="2"
                                              Grid.Column="0"
                                              x:Uid="ScanDebug_ProfileAlignmentModeComboBox"
                                              ItemsSource="{x:Bind ViewModel.AlignmentModeOptions, Mode=OneWay}"
                                              ItemTemplate="{StaticResource ScanAlignmentModeOptionTemplate}"
                                              SelectedItem="{x:Bind ViewModel.SelectedProfileAlignmentMode, Mode=TwoWay}"/>
                                    <ComboBox Grid.Row="2"
                                              Grid.Column="1"
                                              x:Uid="ScanDebug_ProfileDngExportModeComboBox"
                                              ItemsSource="{x:Bind ViewModel.DngExportModeOptions, Mode=OneWay}"
                                              ItemTemplate="{StaticResource ScanDngExportModeOptionTemplate}"
                                              SelectedItem="{x:Bind ViewModel.SelectedProfileDngExportMode, Mode=TwoWay}"/>

                                    <ToggleSwitch Grid.Row="3"
                                                  Grid.Column="0"
                                                  Grid.ColumnSpan="2"
                                                  x:Uid="ScanDebug_CurrentChannelReverseToggleSwitch"
                                                  IsOn="{x:Bind ViewModel.CurrentCalibrationChannelReversed, Mode=TwoWay}"/>
                                    <ToggleSwitch Grid.Row="3"
                                                  Grid.Column="1"
                                                  Grid.ColumnSpan="2"
                                                  x:Uid="Scan_ColorManagementToggleSwitch"
                                                  IsOn="{x:Bind ViewModel.IsScanRecipeColorManagementEnabled, Mode=TwoWay}"/>
                                    <TextBox Grid.Row="4"
                                             Grid.Column="0"
                                             x:Uid="Scan_RedWavelengthTextBox"
                                             Text="{x:Bind ViewModel.ScanRecipeRedWavelengthNm, Mode=TwoWay}"/>
                                    <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             x:Uid="Scan_GreenWavelengthTextBox"
                                             Text="{x:Bind ViewModel.ScanRecipeGreenWavelengthNm, Mode=TwoWay}"/>
                                    <TextBox Grid.Row="5"
                                             Grid.Column="0"
                                             x:Uid="Scan_BlueWavelengthTextBox"
                                             Text="{x:Bind ViewModel.ScanRecipeBlueWavelengthNm, Mode=TwoWay}"/>
                                    <TextBox Grid.Row="5"
                                             Grid.Column="1"
                                             x:Uid="Scan_OutputGammaTextBox"
                                             Text="{x:Bind ViewModel.ScanRecipeOutputGamma, Mode=TwoWay}"/>
                                    <ComboBox Grid.Row="6"
                                              Grid.Column="0"
                                              x:Uid="Scan_TargetWhitePointComboBox"
                                              SelectedValuePath="Tag"
                                              SelectedValue="{x:Bind ViewModel.SelectedScanRecipeTargetWhitePointMode, Mode=TwoWay}">
                                        <ComboBoxItem x:Uid="Scan_TargetWhitePointD65ComboBoxItem" Tag="D65"/>
                                        <ComboBoxItem x:Uid="Scan_TargetWhitePointD50ComboBoxItem" Tag="D50"/>
                                        <ComboBoxItem x:Uid="Scan_TargetWhitePointManualComboBoxItem" Tag="ManualColorTemperature"/>
                                    </ComboBox>
                                    <TextBox Grid.Row="6"
                                             Grid.Column="1"
                                             x:Uid="Scan_ManualWhitePointColorTemperatureTextBox"
                                             Text="{x:Bind ViewModel.ScanRecipeManualWhitePointColorTemperatureK, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ScanDebugSectionCardStyle}">
                        <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                            <TextBlock x:Uid="ScanDebug_ChannelParamsTitle"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                                <TextBlock x:Uid="ScanDebug_ProfileRecipeTitle"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock x:Uid="ScanDebug_ProfileRecipeHelpText"
                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>

                                <TextBlock x:Uid="ScanDebug_ChannelProfileTitle"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <Grid ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                      RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <ComboBox
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        x:Uid="ScanDebug_CalibrationChannelComboBox"
                                        ItemsSource="{x:Bind ViewModel.CalibrationChannelOptions, Mode=OneWay}"
                                        ItemTemplate="{StaticResource ScanCalibrationChannelOptionTemplate}"
                                        SelectedItem="{x:Bind ViewModel.SelectedCalibrationChannel, Mode=TwoWay}"/>
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Text="{x:Bind ViewModel.CalibrationChannelStatusText, Mode=OneWay}"
                                        Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>

                                    <Button Grid.Row="2"
                                            Grid.Column="0"
                                            x:Uid="ScanDebug_SaveChannelButton"
                                            Command="{x:Bind ViewModel.SaveChannelProfileCommand}"/>
                                    <Button Grid.Row="2"
                                            Grid.Column="1"
                                            x:Uid="ScanDebug_ClearChannelButton"
                                            Command="{x:Bind ViewModel.ClearChannelProfileCommand}"/>
                                </Grid>

                                <Grid ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                      RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="0"
                                                Spacing="4">
                                        <TextBox
                                            x:Uid="ScanDebug_SysClockKhzTextBox"
                                            Text="{x:Bind ViewModel.SysClockKhz, Mode=TwoWay}"/>
                                        <TextBlock Text="{x:Bind ViewModel.SysClockMhzDisplay, Mode=OneWay}"
                                                   Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0"
                                                Grid.Column="1"
                                                Spacing="4">
                                        <TextBox
                                            x:Uid="ScanDebug_ExposureTextBox"
                                            Text="{x:Bind ViewModel.ExposureTicks, Mode=TwoWay}"/>
                                        <TextBlock
                                            Text="{x:Bind ViewModel.ExposureTimeDisplay, Mode=OneWay}"
                                            Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="0"
                                                Spacing="4">
                                        <TextBox
                                            x:Uid="ScanDebug_Adc1OffsetTextBox"
                                            Text="{x:Bind ViewModel.Adc1Offset, Mode=TwoWay}"/>
                                        <Border
                                            Padding="8,4"
                                            CornerRadius="6"
                                            Background="{x:Bind ViewModel.Adc1OffsetLimitBrush, Mode=OneWay}">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.Adc1OffsetLimitText, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords"
                                                FontSize="12"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind ViewModel.Adc1OffsetMvDisplay, Mode=OneWay}"
                                                   Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="1"
                                                Spacing="4">
                                        <TextBox
                                            x:Uid="ScanDebug_Adc1GainTextBox"
                                            Text="{x:Bind ViewModel.Adc1Gain, Mode=TwoWay}"/>
                                        <Border
                                            Padding="8,4"
                                            CornerRadius="6"
                                            Background="{x:Bind ViewModel.Adc1GainLimitBrush, Mode=OneWay}">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.Adc1GainLimitText, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords"
                                                FontSize="12"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind ViewModel.Adc1GainVvDisplay, Mode=OneWay}"
                                                   Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2"
                                                Grid.Column="0"
                                                Spacing="4">
                                        <TextBox
                                            x:Uid="ScanDebug_Adc2OffsetTextBox"
                                            Text="{x:Bind ViewModel.Adc2Offset, Mode=TwoWay}"/>
                                        <Border
                                            Padding="8,4"
                                            CornerRadius="6"
                                            Background="{x:Bind ViewModel.Adc2OffsetLimitBrush, Mode=OneWay}">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.Adc2OffsetLimitText, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords"
                                                FontSize="12"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind ViewModel.Adc2OffsetMvDisplay, Mode=OneWay}"
                                                   Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2"
                                                Grid.Column="1"
                                                Spacing="4">
                                        <TextBox
                                            x:Uid="ScanDebug_Adc2GainTextBox"
                                            Text="{x:Bind ViewModel.Adc2Gain, Mode=TwoWay}"/>
                                        <Border
                                            Padding="8,4"
                                            CornerRadius="6"
                                            Background="{x:Bind ViewModel.Adc2GainLimitBrush, Mode=OneWay}">
                                            <TextBlock
                                                Text="{x:Bind ViewModel.Adc2GainLimitText, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords"
                                                FontSize="12"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind ViewModel.Adc2GainVvDisplay, Mode=OneWay}"
                                                   Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                    </StackPanel>

                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="{StaticResource ScanDebugInlineSpacing}">
                                <TextBlock x:Uid="ScanDebug_CurrentIlluminationTitle"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.CurrentCalibrationChannelSummaryText, Mode=OneWay}"
                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                <TextBlock x:Uid="ScanDebug_CurrentIlluminationHelpText"
                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                <Grid
                                    x:Name="CurrentCalibrationIlluminationEditorGrid"
                                    ColumnSpacing="{StaticResource ScanDebugInlineSpacing}"
                                    RowSpacing="{StaticResource ScanDebugInlineSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0"
                                             Grid.Column="0"
                                             x:Name="CurrentCalibrationIlluminationLevelTextBox"
                                             x:Uid="ScanDebug_CurrentIlluminationLevelTextBox"
                                             TextChanged="CurrentCalibrationIlluminationLevelTextBox_TextChanged"/>
                                    <TextBox Grid.Row="0"
