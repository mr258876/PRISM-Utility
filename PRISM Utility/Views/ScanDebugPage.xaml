                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Spacing="2">
                            <TextBlock x:Uid="ScanDebug_Preview"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"/>
                        </StackPanel>
                        <controls:WrapPanel
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            HorizontalSpacing="{StaticResource ScanDebugInlineSpacing}"
                            VerticalSpacing="{StaticResource ScanDebugInlineSpacing}">
                            <Button Content="-"
                                    Click="ZoomOutButton_Click"/>
                            <Button Content="+"
                                    Click="ZoomInButton_Click"/>
                            <ComboBox
                                x:Name="ZoomScaleComboBox"
                                Width="120"
                                SelectionChanged="ZoomScaleComboBox_SelectionChanged"/>
                            <Button x:Uid="ScanDebug_PreviewDisplayToolsButton">
                                <Button.Flyout>
                                    <Flyout Opening="PreviewDisplayToolsFlyout_Opening">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="Width"
                                                        Value="1040"/>
                                                <Setter Property="MinWidth"
                                                        Value="760"/>
                                                <Setter Property="MaxWidth"
                                                        Value="1040"/>
                                                <Setter Property="ScrollViewer.HorizontalScrollMode"
                                                        Value="Disabled"/>
                                                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                                                        Value="Disabled"/>
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        <ScrollViewer MaxHeight="520"
                                                      Width="1040"
                                                      MinWidth="760"
                                                      MaxWidth="1040"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      HorizontalScrollMode="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      VerticalScrollMode="Auto">
                                            <StackPanel x:Name="PreviewDisplayToolsContent"
                                                        x:Load="False"
                                                        Width="1040"
                                                        MinWidth="760"
                                                        Spacing="{StaticResource ScanDebugInlineSpacing}">
                                                <TextBlock x:Uid="ScanDebug_PreviewDisplayToolsDescription"
                                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                                <Grid ColumnSpacing="{StaticResource ScanDebugSectionSpacing}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ToggleSwitch
                                                        Grid.Column="0"
                                                        x:Uid="ScanDebug_GammaCorrectionToggleSwitch"
                                                        IsOn="{x:Bind ViewModel.IsGammaCorrectionEnabled, Mode=TwoWay}"/>
                                                    <ToggleSwitch
                                                        Grid.Column="1"
                                                        x:Uid="ScanDebug_WaterfallCompressionToggleSwitch"
                                                        IsEnabled="{x:Bind ViewModel.IsWaterfallEnabled, Mode=OneWay}"
                                                        IsOn="{x:Bind ViewModel.IsWaterfallCompressedEnabled, Mode=TwoWay}"/>
                                                    <TextBox
                                                        Grid.Column="2"
                                                        x:Uid="ScanDebug_GammaTextBox"
                                                        Width="120"
                                                        IsEnabled="{x:Bind ViewModel.IsGammaCorrectionEnabled, Mode=OneWay}"
                                                        Text="{x:Bind ViewModel.PreviewGamma, Mode=TwoWay}"/>
                                                </Grid>
                                                <ToggleSwitch
                                                    x:Uid="ScanDebug_WhiteLevelPreviewToggleSwitch"
                                                    IsOn="{x:Bind ViewModel.IsWhiteLevelPreviewEnabled, Mode=TwoWay}"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button x:Uid="ScanDebug_OverlayToolsButton">
                                <Button.Flyout>
                                    <Flyout Opening="OverlayToolsFlyout_Opening">
                                        <Flyout.FlyoutPresenterStyle>
                                            <Style TargetType="FlyoutPresenter">
                                                <Setter Property="Width"
                                                        Value="1120"/>
                                                <Setter Property="MinWidth"
                                                        Value="860"/>
                                                <Setter Property="MaxWidth"
                                                        Value="1120"/>
                                                <Setter Property="ScrollViewer.HorizontalScrollMode"
                                                        Value="Disabled"/>
                                                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
                                                        Value="Disabled"/>
                                            </Style>
                                        </Flyout.FlyoutPresenterStyle>
                                        <ScrollViewer MaxHeight="620"
                                                      Width="1120"
                                                      MinWidth="860"
                                                      MaxWidth="1120"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      HorizontalScrollMode="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      VerticalScrollMode="Auto">
                                            <StackPanel x:Name="OverlayToolsContent"
                                                        x:Load="False"
                                                        Width="1120"
                                                        MinWidth="860"
                                                        Spacing="{StaticResource ScanDebugInlineSpacing}">
                                                <TextBlock x:Uid="ScanDebug_RoiScopeDescription"
                                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                                <Grid ColumnSpacing="{StaticResource ScanDebugSectionSpacing}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ToggleSwitch
                                                        Grid.Column="0"
                                                        x:Uid="ScanDebug_RoiEditToggleSwitch"
                                                        IsEnabled="{x:Bind ViewModel.CanEditRoiSelection, Mode=OneWay}"
                                                        IsOn="{x:Bind ViewModel.IsRoiEditModeEnabled, Mode=TwoWay}"/>
                                                    <ComboBox
                                                        Grid.Column="1"
                                                        x:Uid="ScanDebug_RoiTargetComboBox"
                                                        MinWidth="220"
                                                        ItemsSource="{x:Bind ViewModel.RoiSelectionOptions, Mode=OneWay}"
                                                        ItemTemplate="{StaticResource ScanRoiSelectionOptionTemplate}"
                                                        SelectedItem="{x:Bind ViewModel.SelectedRoiSelection, Mode=TwoWay}"/>
                                                </Grid>
                                                <Grid ColumnSpacing="{StaticResource ScanDebugSectionSpacing}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            x:Uid="ScanDebug_ResetSelectedRoiButton"
                                                            Command="{x:Bind ViewModel.ResetSelectedRoiCommand}"/>
                                                    <Button Grid.Column="1"
                                                            x:Uid="ScanDebug_ResetAllRoisButton"
                                                            Command="{x:Bind ViewModel.ResetAllRoisCommand}"/>
                                                </Grid>
                                                <TextBlock x:Uid="ScanDebug_RoiActionScopeText"
                                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                                <TextBlock x:Uid="ScanDebug_VisibleOverlaysText"
                                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                                <Grid ColumnSpacing="{StaticResource ScanDebugSectionSpacing}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              x:Uid="ScanDebug_BwActiveOverlayCheckBox"
                                                              IsChecked="{x:Bind ViewModel.IsBwActiveRoiOverlayVisible, Mode=TwoWay}"/>
                                                    <CheckBox Grid.Column="1"
                                                              x:Uid="ScanDebug_BwShieldOverlayCheckBox"
                                                              IsChecked="{x:Bind ViewModel.IsBwShieldRoiOverlayVisible, Mode=TwoWay}"/>
                                                    <CheckBox Grid.Column="2"
                                                              x:Uid="ScanDebug_FocusOverallOverlayCheckBox"
                                                              IsChecked="{x:Bind ViewModel.IsFocusOverallRoiOverlayVisible, Mode=TwoWay}"/>
                                                    <CheckBox Grid.Column="3"
                                                              x:Uid="ScanDebug_FocusLeftOverlayCheckBox"
                                                              IsChecked="{x:Bind ViewModel.IsFocusLeftRoiOverlayVisible, Mode=TwoWay}"/>
                                                    <CheckBox Grid.Column="4"
                                                              x:Uid="ScanDebug_FocusRightOverlayCheckBox"
                                                              IsChecked="{x:Bind ViewModel.IsFocusRightRoiOverlayVisible, Mode=TwoWay}"/>
                                                </Grid>
                                                <TextBlock Text="{x:Bind ViewModel.RoiStatusText, Mode=OneWay}"
                                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                                <Grid ColumnSpacing="{StaticResource ScanDebugInlineSpacing}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Width="160"
                                                             x:Uid="ScanDebug_RoiStartTextBox"
                                                             Text="{x:Bind ViewModel.RoiStartInput, Mode=TwoWay}"/>
                                                    <TextBox Grid.Column="1"
                                                             Width="160"
                                                             x:Uid="ScanDebug_RoiEndTextBox"
                                                             Text="{x:Bind ViewModel.RoiEndInput, Mode=TwoWay}"/>
                                                    <Button Grid.Column="2"
                                                            x:Uid="ScanDebug_ApplyRoiButton"
                                                            VerticalAlignment="Bottom"
                                                            Command="{x:Bind ViewModel.ApplySelectedRoiInputsCommand}"/>
                                                </Grid>
                                                <TextBlock Text="{x:Bind ViewModel.RoiInputStatusText, Mode=OneWay}"
                                                           Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </controls:WrapPanel>
                    </Grid>

                    <Border
                        Grid.Row="1"
                        MinHeight="{StaticResource ScanDebugPreviewMinimumHeight}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="{StaticResource ScanDebugCardBorderThickness}"
                        CornerRadius="{StaticResource ScanDebugCardCornerRadius}"
                        Padding="{StaticResource ScanDebugPreviewPadding}">
                        <Grid>
                            <ScrollViewer
                                x:Name="PreviewScrollViewer"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollMode="Enabled"
                                VerticalScrollMode="Enabled"
                                ZoomMode="Enabled"
                                MinZoomFactor="0.1"
                                MaxZoomFactor="20"
                                SizeChanged="PreviewScrollViewer_SizeChanged"
                                ViewChanged="PreviewScrollViewer_ViewChanged"
                                PointerPressed="PreviewScrollViewer_PointerPressed"
                                PointerMoved="PreviewScrollViewer_PointerMoved"
                                PointerReleased="PreviewScrollViewer_PointerReleased"
                                PointerCanceled="PreviewScrollViewer_PointerCanceled"
                                PointerWheelChanged="PreviewScrollViewer_PointerWheelChanged">
                                <Canvas x:Name="PreviewCanvas">
                                    <canvas:CanvasControl
                                        x:Name="PreviewCanvasControl"
                                        ClearColor="Transparent"
                                        CreateResources="PreviewCanvasControl_CreateResources"
                                        Draw="PreviewCanvasControl_Draw"
                                        PointerPressed="PreviewCanvasControl_PointerPressed"
                                        PointerMoved="PreviewCanvasControl_PointerMoved"
                                        PointerReleased="PreviewCanvasControl_PointerReleased"
                                        PointerCanceled="PreviewCanvasControl_PointerCanceled"
                                        PointerExited="PreviewCanvasControl_PointerExited"/>
                                    <Canvas x:Name="RoiCanvas"
                                            IsHitTestVisible="False"/>
                                    <Canvas x:Name="AxisCanvas"
                                            IsHitTestVisible="False"/>
                                </Canvas>
                            </ScrollViewer>
                            <Grid
                                x:Name="PreviewEmptyStateGrid"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="{StaticResource ScanDebugInlineSpacing}">
                                    <TextBlock x:Uid="ScanDebug_PreviewEmptyTitle"
                                               HorizontalAlignment="Center"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock x:Uid="ScanDebug_PreviewEmptyDescription"
                                               HorizontalAlignment="Center"
                                               Style="{StaticResource ScanDebugQuietTextBlockStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2"
                          ColumnSpacing="{StaticResource ScanDebugSectionSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="{StaticResource ScanDebugInlineSpacing}">
                            <TextBlock x:Name="CursorPositionTextBlock"/>
                            <TextBlock x:Name="CursorIntensityTextBlock"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
